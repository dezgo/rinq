# Tina - Twilio PBX Manager
# Bot-specific environment variables
# Shared variables (BOT_API_KEY, GOOGLE_CLIENT_ID, etc.) are in /bot-team/.env

# Flask secret key for session signing (REQUIRED for web UI)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here

# Twilio API credentials (from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here

# API Key for browser softphone (create at: console.twilio.com -> Account -> API keys)
# Required for the browser-based phone to work
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your-api-secret-here

# TwiML App SID for browser softphone (create at: console.twilio.com -> Voice -> TwiML Apps)
# Set the Voice Request URL to: https://your-tina-url/api/voice/outbound
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook URL - where Twilio should send incoming call requests
# For local testing with ngrok: https://abc123.ngrok.io
# For production: https://tina.watsonblinds.com.au
# If not set, you'll need to configure voice URLs manually in Twilio Console
TINA_WEBHOOK_URL=

# SIP Credential List SID for desk phone management
# Find at: console.twilio.com -> Voice -> SIP -> Credential Lists
# This enables the "Desk Phones" admin page to manage SIP usernames/passwords
TWILIO_SIP_CREDENTIAL_LIST_SID=CLxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Google Group email for call recordings
# TWILIO_RECORDING_EMAIL=recordings@yourcompany.com

# =============================================================================
# AI Receptionist (Rosie)
# =============================================================================

# Rosie's public webhook URL. When set, unanswered calls redirect to Rosie
# instead of voicemail. If not set, voicemail is used as fallback.
ROSIE_WEBHOOK_URL=https://rosie.watsonblinds.com.au

# =============================================================================
# TTS Configuration (for AI-generated audio messages)
# =============================================================================

# ElevenLabs TTS - Premium quality Australian voices (~$0.30/1K chars)
# Get key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Cartesia TTS - Sonic 3 with emotion/voice direction (~$0.06/1K chars)
# Get key at: https://play.cartesia.ai/
CARTESIA_API_KEY=

# Google Cloud TTS - Uses shared service account (no API key needed)
# Credentials at: /bot-team/.secrets/google/credentials.json
# Ensure "Cloud Text-to-Speech API" is enabled in Google Cloud Console
