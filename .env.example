# Rinq Configuration
FLASK_SECRET_KEY=change-me-to-a-random-string

# Google OAuth (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twilio (required for phone functionality)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_DEFAULT_CALLER_ID=
TWILIO_SIP_CREDENTIAL_LIST_SID=

# Server
PORT=5000
RINQ_WEBHOOK_URL=https://your-domain.com

# Multi-tenant (optional — omit for single-tenant)
# RINQ_MULTI_TENANT=true
# RINQ_DATA_DIR=/path/to/data

# Domain restrictions (optional, comma-separated)
# RINQ_ALLOWED_DOMAINS=example.com,other.com
# RINQ_ADMIN_EMAILS=admin@example.com

# TTS (optional)
# ELEVENLABS_API_KEY=
# CARTESIA_API_KEY=

# Google Workspace (optional, for recordings via Drive/Gmail)
# GOOGLE_CREDENTIALS_FILE=/path/to/credentials.json
# GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@example.com

# Watson Blinds integration (only when running inside bot-team)
# RINQ_AUTH=gateway
# RINQ_INTEGRATIONS=watson
# BOT_API_KEY=
